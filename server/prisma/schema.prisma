// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EmpresaEstado {
  ACTIVO
  SUSPENDIDO
  INACTIVO
}

enum UsuarioEstado {
  ACTIVO
  INACTIVO
}

enum Rol {
  SUPER_ADMIN
  ADMIN
  VENDEDOR
  IMPORTADOR
}

enum Incoterm {
  EXW
  FOB
  FCA
}

enum Moneda {
  USD
  EUR
  PEN
}

enum CosteoEstado {
  BORRADOR
  TERMINADO
}

model CosteoImportacion {
  id                    String                @id @default(uuid())
  codigo                String                // AAAA-99999
  empresaId             String
  empresa               Empresa               @relation(fields: [empresaId], references: [id])
  clienteId             String?
  cliente               Cliente?              @relation(fields: [clienteId], references: [id])
  clienteNombre         String?
  clienteDocumento      String?
  ordenId               String?               @unique
  orden                 Orden?                @relation(fields: [ordenId], references: [id])
  nroFacturaComercial   String?
  proveedorExtranjero   String?
  incoterm              Incoterm
  moneda                Moneda
  tipoCambio            Float
  observaciones         String?
  
  // Totales
  totalFacturaComercial Float
  gastosOrigen          Float                 @default(0)
  fleteInternacional    Float                 @default(0)
  seguro                Float                 @default(0)
  gastosLocales         Float                 @default(0)
  
  adValoremGlobal       Float                 @default(0)
  percepcionPorcentaje  Float                 @default(0)
  
  // Logistics
  fechaEmbarque         DateTime?
  fechaLlegada          DateTime?
  canal                 CanalImportacion?
  modalidad             ModalidadImportacion @default(AEREO)
  nroDAM                String?
  tipoCarga             String?
  nroContenedor         String?
  
  // Calculated stored values
  cifGlobal             Float
  baseImponible         Float
  igv                   Float
  ipm                   Float
  percepcionMonto       Float
  costoTotalImportacion Float
  ratioImportacion      Float                 @default(0)
  estado                CosteoEstado          @default(BORRADOR)

  items                 CosteoImportacionItem[]
  
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@unique([codigo, empresaId])
}

model CosteoImportacionItem {
  id                      String            @id @default(uuid())
  costeoId                String
  costeo                  CosteoImportacion @relation(fields: [costeoId], references: [id], onDelete: Cascade)
  sku                     String?
  producto                String
  cantidad                Float
  valorUnitario           Float
  valorTotal              Float
  adValoremPorcentaje     Float?
  
  // Calculated per item
  participacionPorcentual Float
  cifOculto               Float
  adValoremMonto          Float
  fleteUnitario           Float
  seguroUnitario          Float
  gastosOrigenUnitario    Float
  gastosLocalesUnitario   Float
  costoTotalUnitario      Float
  costoTotalSoles         Float
  
  // Sales Projection
  precioVentaPEN          Float             @default(0)
  descuentoPorcentaje     Float             @default(0)
  utilidadUnitarioPEN     Float             @default(0)
  utilidadTotalPEN        Float             @default(0)
  margenPorcentaje        Float             @default(0)

  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
}

enum CotizacionEstado {
  BORRADOR
  ENVIADA
  APROBADA
  RECHAZADA
}

enum OrdenEstado {
  COORDINACION_EMBARQUE
  EN_TRANSITO
  EN_PUERTO
  NUMERADA
  ENTREGADA
  DESPACHO_CULMINADO
}

enum ModalidadImportacion {
  AEREO
  MARITIMO
  MULTIMODAL
}

enum CanalImportacion {
  VERDE
  AMARILLO
  ROJO
  SIN_CANAL
}

model Empresa {
  id            String        @id @default(uuid())
  ruc           String        @unique
  razonSocial   String
  contacto      String
  celular       String
  correo        String
  fechaInicio   DateTime
  fechaFin      DateTime?
  estado        EmpresaEstado @default(ACTIVO)
  usuarios      Usuario[]
  clientes      Cliente[]
  leads         Lead[]
  proveedores   Proveedor[]
  categorias    Categoria[]
  cotizaciones  Cotizacion[]
  costeos       CosteoImportacion[]
  giroNegocios  GiroNegocio[]
  bancos        Banco[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Lead {
  id           String       @id @default(uuid())
  nombre       String?      
  ruc          String?      
  razonSocial  String?      
  direccion    String?      
  direccionNro String?
  direccionInt String?
  direccionRef String?
  contacto     String       
  correo       String?      
  celular      String?      
  estado       LeadEstado   @default(NUEVO_CONTACTO)
  empresaId    String
  empresa      Empresa      @relation(fields: [empresaId], references: [id])
  cotizaciones Cotizacion[]
  giroNegocio  String?
  contactos    String?
  estadoChangedAt DateTime  @default(now())
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum LeadEstado {
  NUEVO_CONTACTO
  CONTACTADO
  COTIZANDO
  CERRADO_GANADO
  CERRADO_PERDIDO
}

model Usuario {
  id           String        @id @default(uuid())
  username     String        @unique
  password     String
  nombres      String
  apellidos    String
  celular      String?
  correo       String        @unique
  estado       UsuarioEstado @default(ACTIVO)
  rol          Rol
  empresaId    String?
  empresa      Empresa?      @relation(fields: [empresaId], references: [id])
  cotizaciones Cotizacion[]
  cotizacionesHistorial CotizacionEstadoHistorial[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Cliente {
  id               String       @id @default(uuid())
  ruc              String
  razonSocial      String
  direccion        String
  direccionNro     String?
  direccionInt     String?
  direccionRef     String?
  direccionEntrega String?
  direccionEntregaNro String?
  direccionEntregaInt String?
  direccionEntregaRef String?
  contacto         String
  correo           String?
  celular          String?
  empresaId        String
  empresa          Empresa      @relation(fields: [empresaId], references: [id])
  cotizaciones     Cotizacion[]
  costeos          CosteoImportacion[]
  giroNegocio      String?
  contactos        String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([ruc, empresaId])
}

model Proveedor {
  id               String            @id @default(uuid())
  ruc              String
  razonSocial      String
  correos          String[] // Lista de correos
  empresaId        String
  empresa          Empresa           @relation(fields: [empresaId], references: [id])
  cotizacionLineas CotizacionLinea[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([ruc, empresaId])
}

model Categoria {
  id         String     @id @default(uuid())
  nombre     String
  afectoIGV  Boolean    @default(true)
  empresaId  String
  empresa    Empresa    @relation(fields: [empresaId], references: [id])
  conceptos  Concepto[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Concepto {
  id                 String            @id @default(uuid())
  nombre             String
  incluirPorDefecto  Boolean           @default(false)
  categoriaId        String
  categoria          Categoria         @relation(fields: [categoriaId], references: [id])
  cotizacionLineas   CotizacionLinea[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model Cotizacion {
  id                String           @id @default(uuid())
  numero            Int              @default(autoincrement())
  estado            CotizacionEstado @default(BORRADOR)
  clienteId         String?
  cliente           Cliente?         @relation(fields: [clienteId], references: [id])
  leadId            String?
  lead              Lead?            @relation(fields: [leadId], references: [id])
  vendedorId        String
  vendedor          Usuario          @relation(fields: [vendedorId], references: [id])
  empresaId         String
  empresa           Empresa          @relation(fields: [empresaId], references: [id])
  pais              String           @default("PERÚ")
  moneda            Moneda           @default(USD)
  lineas            CotizacionLinea[]
  totalVenta        Float            @default(0)
  igv               Float            @default(0)
  precioTotal       Float            @default(0)
  utilidad          Float            @default(0)
  porcentajeUtilidad Float           @default(0)
  historial         CotizacionEstadoHistorial[]
  orden             Orden?
  ordenId           String?
  ordenAsociada     Orden?           @relation(fields: [ordenId], references: [id], name: "OrdenAsociada")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model CotizacionEstadoHistorial {
  id           String           @id @default(uuid())
  cotizacionId String
  cotizacion   Cotizacion       @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  estado       CotizacionEstado
  usuarioId    String
  usuario      Usuario          @relation(fields: [usuarioId], references: [id])
  fechaHora    DateTime         @default(now())
}

model CotizacionLinea {
  id            String     @id @default(uuid())
  cotizacionId  String
  cotizacion    Cotizacion @relation(fields: [cotizacionId], references: [id], onDelete: Cascade)
  conceptoId    String
  concepto      Concepto   @relation(fields: [conceptoId], references: [id])
  proveedorId   String?
  proveedor     Proveedor? @relation(fields: [proveedorId], references: [id])
  costo         Float      @default(0)
  precioVenta   Float      @default(0)
  valorVenta    Float      @default(0)
  igv           Float      @default(0)
  utilidad      Float      @default(0)
  margen        Float      @default(0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Orden {
  id               String       @id @default(uuid())
  correlativo      Int
  anio             Int
  cotizacionId     String?      @unique
  cotizacion       Cotizacion?  @relation(fields: [cotizacionId], references: [id])
  cotizacionesAsociadas Cotizacion[] @relation(name: "OrdenAsociada")
  nroBL            String?
  nroDAM           String?
  canal            CanalImportacion?
  fechaETD         DateTime?
  fechaETA         DateTime?
  proveedorExtranjero   String?
  nroFacturaComercial   String?
  tipoCarga             String?
  nroContenedor         String?
  fechaRealEntrega DateTime?
  referencia       String?
  email            String?
  estado           OrdenEstado  @default(COORDINACION_EMBARQUE)
  costeo           CosteoImportacion?
  historial        OrdenEstadoHistorial[]
  pagos            OrdenPago[]
  cobros           Cobro[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model OrdenEstadoHistorial {
  id        String      @id @default(uuid())
  ordenId   String
  orden     Orden       @relation(fields: [ordenId], references: [id])
  estado    OrdenEstado
  fechaHora DateTime    @default(now())
}

model OrdenPago {
  id        String   @id @default(uuid())
  ordenId   String
  orden     Orden    @relation(fields: [ordenId], references: [id])
  monto     Float
  modo      String   // Transferencia, Yape, Plin, etc.
  fecha     DateTime @default(now())
  createdAt DateTime @default(now())
}

model MetodoPago {
  id     String @id @default(uuid())
  nombre String @unique
}

model Cobro {
  id              String         @id @default(uuid())
  ordenId         String
  orden           Orden          @relation(fields: [ordenId], references: [id])
  moneda          Moneda         // USD, EUR or PEN
  monto           Float
  metodo          String         // EFECTIVO, TRANSFERENCIA, TARJETA_CREDITO, TARJETA_DEBITO, YAPE, PLIN, SIP
  tipoDocumento   String?        // Legacy or global Tipo Doc
  nroDocumento    String?        // Legacy or global Documento
  fechaDocumento  DateTime?      // Legacy or global Fecha Doc
  lineasIds       String[]       // CotizacionLinea IDs that this payment applies to
  referencia      String?        // Nro de referencia opcional del cobro (ej. operacion bancaria)
  detallesLineas  String?        // JSON stringified holding concept-specific billing docs
  tipoCambio      Float          @default(1)
  banco           String?
  createdAt       DateTime       @default(now())
}

model GiroNegocio {
  id        String   @id @default(uuid())
  nombre    String
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nombre, empresaId])
}

model Banco {
  id        String   @id @default(uuid())
  nombre    String
  empresaId String
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nombre, empresaId])
}

